# Required: your Buildin.ai bot integration token.
# Get it from Buildin.ai → Settings → Integrations → Create new bot integration.
BUILDIN_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the API base URL (default: https://api.buildin.ai/v1).
# BUILDIN_API_BASE_URL=https://api.buildin.ai/v1

# Optional: a parent page ID to use for the live smoke test (npm run smoke).
# Without it, the smoke test that creates pages is skipped.
# BUILDIN_TEST_PARENT_PAGE_ID=00000000-0000-0000-0000-000000000000
